---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<p class="kicker">个人博客 · 随手记 · 慢慢写</p>
				<h1>笨驴（Dumb Donkey）</h1>
				<p class="desc">
					这里放一些做东西的记录、踩坑、想法，以及偶尔的长文。
					不追热点，只追清楚。
				</p>
				<div class="cta">
					<a class="primary" href="/blog">去看文章</a>
					<a class="secondary" href="/about">关于我</a>
				</div>
				<p class="meta">
					GitHub：<a href="https://github.com/ben-ben2018" target="_blank" rel="me">ben-ben2018</a>
				</p>
			</section>

			<section class="game-grid" aria-label="我在玩的游戏">
				<article class="game-card yysls">
					<div class="game-top">
						<p class="tag">在玩</p>
						<h2>燕云十六声</h2>
						<p class="subtitle">江湖与人间烟火，都在同一张地图上。</p>
					</div>
					<p class="game-desc">
						偏写意的国风武侠氛围：古建、器物、民俗与“十六声”的文化意象。适合慢慢逛、慢慢练。
					</p>
					<div class="game-actions">
						<a class="game-link" href="https://www.yysls.cn/index.html" target="_blank" rel="noopener">官网</a>
					</div>
				</article>

				<article class="game-card sky">
					<div class="game-top">
						<p class="tag">在玩</p>
						<h2>光·遇</h2>
						<p class="subtitle">光是遇见，就很美好。</p>
					</div>
					<p class="game-desc">
						柔和、干净、偏治愈的气质：探索、飞行、社交与陪伴感。适合在压力大的时候把心放慢。
					</p>
					<div class="game-actions">
						<a class="game-link" href="https://sky.163.com/" target="_blank" rel="noopener">官网</a>
					</div>
				</article>
			</section>

			<section class="tip">
				<p>
					想测试 Cloudflare Pages 自动部署？你已经成功了。
					下次我们可以把默认示例文章清掉，换成真正的内容目录和写作流程。
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home {
		max-width: 72rem;
		margin: 0 auto;
		padding: 3.5rem 1rem 3rem;
	}
	.hero {
		padding: 2.25rem 1.75rem;
		border: 1px solid rgba(var(--gray-light), 1);
		border-radius: 1.25rem;
		background: linear-gradient(135deg, rgba(var(--accent), 0.08), rgba(var(--accent), 0.02));
	}
	.kicker {
		margin: 0 0 0.5rem 0;
		color: rgb(var(--gray));
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-size: 0.85rem;
	}
	h1 {
		margin: 0 0 0.75rem 0;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.1;
	}
	.desc {
		margin: 0 0 1.25rem 0;
		color: rgb(var(--gray-dark));
		max-width: 56ch;
	}
	.cta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin: 1rem 0 0.75rem;
	}
	.cta a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		border-radius: 0.8rem;
		text-decoration: none;
		font-weight: 600;
		border: 1px solid rgba(var(--accent), 0.35);
	}
	.primary {
		background: rgb(var(--accent));
		color: white;
		border-color: rgb(var(--accent));
	}
	.secondary {
		background: rgba(255, 255, 255, 0.65);
		color: rgb(var(--black));
	}
	.meta {
		margin: 0.25rem 0 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
	.game-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}
	.game-card {
		position: relative;
		padding: 1.35rem 1.25rem;
		border-radius: 1.25rem;
		border: 1px solid rgba(var(--gray-light), 1);
		background: white;
		overflow: hidden;
	}
	.game-card::before {
		content: '';
		position: absolute;
		inset: 0;
		opacity: 0.9;
		pointer-events: none;
	}
	.game-card .tag {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.25rem 0.55rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		background: rgba(255, 255, 255, 0.75);
		border: 1px solid rgba(255, 255, 255, 0.85);
	}
	.game-top h2 {
		margin: 0.6rem 0 0.25rem;
		font-size: 1.35rem;
	}
	.game-top .subtitle {
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	.game-desc {
		margin: 0.85rem 0 0;
		color: rgb(var(--gray-dark));
		max-width: 64ch;
	}
	.game-actions {
		margin-top: 1rem;
	}
	.game-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 0.85rem;
		border-radius: 0.85rem;
		text-decoration: none;
		font-weight: 650;
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid rgba(var(--gray-light), 1);
		color: rgb(var(--black));
	}
	.game-link:hover {
		transform: translateY(-1px);
	}
	/* 风格：燕云十六声（国风·暮色金） */
	.game-card.yysls {
		background: linear-gradient(135deg, rgba(120, 68, 26, 0.12), rgba(255, 208, 139, 0.12));
		border-color: rgba(120, 68, 26, 0.18);
	}
	.game-card.yysls::before {
		background:
			radial-gradient(800px 260px at 20% 0%, rgba(255, 208, 139, 0.55), transparent 60%),
			radial-gradient(700px 320px at 120% 30%, rgba(120, 68, 26, 0.35), transparent 55%),
			linear-gradient(135deg, rgba(255, 244, 226, 0.65), rgba(255, 255, 255, 0));
	}
	/* 风格：光遇（清澈·天光蓝） */
	.game-card.sky {
		background: linear-gradient(135deg, rgba(76, 168, 255, 0.10), rgba(188, 236, 255, 0.12));
		border-color: rgba(76, 168, 255, 0.20);
	}
	.game-card.sky::before {
		background:
			radial-gradient(700px 260px at 25% 10%, rgba(188, 236, 255, 0.65), transparent 55%),
			radial-gradient(700px 320px at 115% 40%, rgba(76, 168, 255, 0.35), transparent 55%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0));
	}

	.tip {
		margin-top: 1rem;
		padding: 1rem 1.15rem;
		border-left: 4px solid rgba(var(--accent), 0.75);
		background: rgba(var(--accent), 0.06);
		border-radius: 0.75rem;
	}
	.tip p {
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 900px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>
